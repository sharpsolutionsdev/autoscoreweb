{
  "manifest_version": 3,
  "name": "DartVoice Launchpad",
  "version": "1.0",
  "description": "Voice-control any browser dart scorer. Start scoring without clicking.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Launch DartVoice",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "declarativeNetRequest"],
  "host_permissions": ["*://*.dartcounter.net/*", "*://nakka.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["*://*.dartcounter.net/*", "*://nakka.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "dartvoice_unblock_frames",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
