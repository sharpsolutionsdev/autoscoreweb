{
  "manifest_version": 3,
  "name": "DartVoice Launchpad",
  "version": "2.1.3",
  "description": "Voice-score darts in your browser. Open the DartVoice web app, connect your scorer, call your throws. Free 10-minute demo.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "DartVoice",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "declarativeNetRequest"],
  "host_permissions": ["*://*.dartcounter.net/*", "*://nakka.com/*", "*://dartvoice.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.dartcounter.net/*", "*://nakka.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["*://dartvoice.app/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "dartvoice_unblock_frames",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
