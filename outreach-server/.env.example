# Copy to .env and fill in

# ── Supabase (service role bypasses RLS) ───────────────────────────────────
SUPABASE_URL=https://poyjykgqsvgimssbhsuz.supabase.co
SUPABASE_SERVICE_KEY=

# ── Worker ─────────────────────────────────────────────────────────────────
PORT=3050
POLL_INTERVAL_MS=20000
# Global kill-switch. Set to true only when you're sure.
BOT_ENABLED=false

# ── Reddit (OAuth "script" app) ────────────────────────────────────────────
# Create one at https://www.reddit.com/prefs/apps -> "create another app" -> script
REDDIT_USER_AGENT=dartvoice-outreach/0.1 by your_reddit_username
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Don't exceed 1 DM / 5 min or you'll get rate-limited + shadowbanned
REDDIT_MIN_GAP_MS=300000

# ── X (Twitter) — requires paid Basic tier ($200/mo) or higher ─────────────
# https://developer.x.com/en/portal/products
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Facebook / Instagram / TikTok ──────────────────────────────────────────
# No supported cold-DM path via official APIs. Leave blank.
# If you're running a browser-automation fallback (puppeteer etc.), see README.
