  "bugs": {
    "url": "https://github.com/sharpsolutionsdev/autoscoreweb/issues"
  },
  "homepage": "https://github.com/sharpsolutionsdev/autoscoreweb#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tailwindcss": "^3.4.19"
  }
}
